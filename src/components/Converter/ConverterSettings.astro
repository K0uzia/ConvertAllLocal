---
import './ConverterSettings.css';
---

<section class="converter-settings" data-converter-settings aria-labelledby="converter-settings-title">
  <h2 class="converter-settings__title" id="converter-settings-title">
    <i class="converter-settings__title-icon fa-solid fa-sliders" aria-hidden="true"></i>
    <span>Paramètres locaux</span>
  </h2>
  <p class="converter-settings__lead">
    Ces réglages sont enregistrés uniquement dans le stockage local de votre navigateur. Aucune
    donnée n'est envoyée sur un serveur. Les formats par défaut s'appliquent aux nouveaux fichiers
    ajoutés et aux fichiers encore en attente dans la file.
  </p>

  <div class="converter-settings__table-wrap">
    <table class="converter-settings__table">
      <colgroup>
        <col class="converter-settings__col-param" />
        <col class="converter-settings__col-desc" />
        <col class="converter-settings__col-action" />
      </colgroup>
      <thead>
        <tr>
          <th scope="col">Paramètre</th>
          <th scope="col">Description</th>
          <th scope="col">Action</th>
        </tr>
      </thead>
      <tbody>
        <tr class="converter-settings__row-format">
          <th scope="row">Image</th>
          <td>
            <label class="converter-settings__field" for="settings-output-image">
              <span class="converter-settings__field-hint">WebP, PNG, JPEG, AVIF ou PDF</span>
              <select
                id="settings-output-image"
                class="converter-settings__select"
                data-settings-output="image"
                aria-label="Format de sortie par défaut pour les images"
              ></select>
            </label>
          </td>
          <td class="converter-settings__action-cell" rowspan="3">
            <p class="converter-settings__summary">
              <span class="converter-settings__summary-label">Résumé</span>
              <strong data-settings-output-value>Image: WebP, Audio: WAV, Document: JSON</strong>
            </p>
            <button type="button" class="converter-settings__btn" data-settings-reset-output>
              Réinitialiser les formats
            </button>
          </td>
        </tr>
        <tr class="converter-settings__row-format">
          <th scope="row">Audio</th>
          <td>
            <label class="converter-settings__field" for="settings-output-audio">
              <span class="converter-settings__field-hint">WAV, MP3 ou OGG (selon l'entrée)</span>
              <select
                id="settings-output-audio"
                class="converter-settings__select"
                data-settings-output="audio"
                aria-label="Format de sortie par défaut pour l'audio"
              ></select>
            </label>
          </td>
        </tr>
        <tr class="converter-settings__row-format">
          <th scope="row">Document</th>
          <td>
            <label class="converter-settings__field" for="settings-output-document">
              <span class="converter-settings__field-hint">HTML, texte, JSON, CSV ou PDF (selon l'entrée)</span>
              <select
                id="settings-output-document"
                class="converter-settings__select"
                data-settings-output="document"
                aria-label="Format de sortie par défaut pour les documents"
              ></select>
            </label>
          </td>
        </tr>
        <tr>
          <th scope="row">Données locales</th>
          <td>
            Clés <code>cal:*</code> dans <code>localStorage</code> :
            <strong data-settings-keys-count>0</strong>
          </td>
          <td>
            <button type="button" class="converter-settings__btn" data-settings-clear-storage>
              Tout effacer
            </button>
          </td>
        </tr>
      </tbody>
    </table>
  </div>
</section>

<script>
  import { initConverterSettings } from './converter-settings-ui.ts';

  initConverterSettings();
  document.addEventListener('astro:page-load', initConverterSettings);
</script>
