---
/** Motif hero : carrés imbriqués. */
interface Props {
  variant?: 'base' | 'accent';
}

const { variant = 'base' } = Astro.props;

const cx = 600;
const cy = 600;

const squares = [
  { half: 600, rotate: 12 },
  { half: 500, rotate: 24 },
  { half: 400, rotate: 36 },
  { half: 300, rotate: 48 },
  { half: 200, rotate: 60 },
  { half: 100, rotate: 72 },
];
---

<svg
  class:list={['hero-geo__motif', variant === 'accent' && 'hero-geo__motif--accent']}
  viewBox="0 0 1200 1200"
  preserveAspectRatio="xMidYMid slice"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
  focusable="false"
>
  <g class="hero-geo__squares">
    {
      squares.map((square, index) => (
        <rect
          x={cx - square.half}
          y={cy - square.half}
          width={square.half * 2}
          height={square.half * 2}
          transform={`rotate(${square.rotate} ${cx} ${cy})`}
          class:list={['hero-geo__square', index % 2 === 1 && 'hero-geo__square--accent']}
        />
      ))
    }
  </g>
</svg>
