---
import './Hero.css';
import Header from '../Header/Header.astro';
import HeroGeoMotif from './HeroGeoMotif.astro';
---

<section class="hero" aria-labelledby="hero-title">
  <div class="hero__bg" aria-hidden="true">
    <HeroGeoMotif />
    <div class="hero-geo__halo">
      <HeroGeoMotif variant="accent" />
    </div>
  </div>
  <div class="hero__shell">
  <div class="hero__main">
    <div class="hero__container">
      <h1 class="hero__title" id="hero-title">
        <span class="hero__title-group">
          <span class="hero__title-line hero__title-line--primary">La conversion</span>
          <span class="hero__title-line hero__title-line--primary">de fichiers</span>
        </span>
        <span class="hero__title-line hero__title-line--enfin">
          enfin
          <span class="hero__rotate" aria-label="gratuite, locale, rapide">
            <span class="hero__rotate-sizer" aria-hidden="true">gratuite</span>
            <span class="hero__rotate-clip">
              <span class="hero__rotate-track">
                <span class="hero__rotate-word">gratuite</span>
                <span class="hero__rotate-word">locale</span>
                <span class="hero__rotate-word">rapide</span>
                <span class="hero__rotate-word">gratuite</span>
              </span>
            </span>
          </span>
        </span>
      </h1>

      <p class="hero__lead">
        <span class="hero__lead-part">
          Images, audio, documents et PDF&nbsp;: conversion locale dans le navigateur, sans upload
          ni&nbsp;compte.
          Vos fichiers restent sur votre machine, open&nbsp;source et sans limite cachée.
        </span>
      </p>
    </div>
  </div>

  <Header variant="hero" />
  </div>
</section>

<script>
  import { initHeaderPin } from '../Header/header-pin.ts';
  import { initHeroGeoHalo } from '../SiteGeo/site-geo-halo.ts';

  initHeaderPin();
  initHeroGeoHalo();
  document.addEventListener('astro:page-load', () => {
    initHeaderPin();
    initHeroGeoHalo();
  });
</script>
